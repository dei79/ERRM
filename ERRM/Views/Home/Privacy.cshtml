@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="info-panel">
    <span class="eyebrow">Privacy</span>
    <h1 class="display-6">@ViewData["Title"]</h1>
    <p class="lead mb-3">Use this page to describe how employee evaluation data is stored, processed, and protected.</p>
    <p class="text-muted mb-0">
        This application can contain sensitive HR-related content, so the privacy policy should clearly explain retention, access controls, and data handling expectations.
    </p>
</section>

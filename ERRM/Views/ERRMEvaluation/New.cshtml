@model ERRM.Models.EvaluationViewModel

@{
    ViewData["Title"] = "New Evaluation";
}

<h1 class="display-5 mb-4">New evaluation</h1>

<form asp-action="New" asp-controller="ERRMEvaluation" method="post" class="row g-4">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="col-12">
        <h2 class="h4">Issuer of the evaluation</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="CompanyName" class="form-label"></label>
                <input asp-for="CompanyName" class="form-control" />
                <span asp-validation-for="CompanyName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CompanyLocation" class="form-label"></label>
                <input asp-for="CompanyLocation" class="form-control" />
                <span asp-validation-for="CompanyLocation" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="IssuingLocation" class="form-label"></label>
                <input asp-for="IssuingLocation" class="form-control" />
                <span asp-validation-for="IssuingLocation" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="FirstSignerName" class="form-label"></label>
                <input asp-for="FirstSignerName" class="form-control" />
                <span asp-validation-for="FirstSignerName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="SecondSignerName" class="form-label"></label>
                <input asp-for="SecondSignerName" class="form-control" />
                <span asp-validation-for="SecondSignerName" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="col-12">
        <h2 class="h4">General information about the person</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Salutation" class="form-label"></label>
                <select asp-for="Salutation" class="form-select">
                    <option value="">Select salutation</option>
                    <option value="Mr">Mr</option>
                    <option value="Mrs">Mrs</option>
                </select>
                <span asp-validation-for="Salutation" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="AcademicTitle" class="form-label"></label>
                <input asp-for="AcademicTitle" class="form-control" />
                <span asp-validation-for="AcademicTitle" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DateOfBirth" class="form-label"></label>
                <input asp-for="DateOfBirth" class="form-control" type="date" />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="col-12">
        <h2 class="h4">Information to the position</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Department" class="form-label"></label>
                <input asp-for="Department" class="form-control" />
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Position" class="form-label"></label>
                <input asp-for="Position" class="form-control" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="col-12">
        <h2 class="h4">Evaluation questions</h2>
        <div class="row g-3">
            @for (var i = 0; i < Model.CriteriaAnswers.Count; i++)
            {
                <div class="col-12">
                    <div class="border rounded p-3">
                        <input asp-for="CriteriaAnswers[i].Title" type="hidden" />
                        <input asp-for="CriteriaAnswers[i].Description" type="hidden" />
                        <input asp-for="CriteriaAnswers[i].RatingScale" type="hidden" />
                        <input asp-for="CriteriaAnswers[i].CommentAllowed" type="hidden" />

                        <h3 class="h5 mb-1">@Model.CriteriaAnswers[i].Title</h3>
                        <p class="text-muted mb-3">@Model.CriteriaAnswers[i].Description</p>

                        <div class="row g-3">
                            <div class="col-md-3">
                                <label asp-for="CriteriaAnswers[i].Rating" class="form-label">Rating (1-5)</label>
                                <select asp-for="CriteriaAnswers[i].Rating" class="form-select">
                                    <option value="">Select rating</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                    <option value="4">4</option>
                                    <option value="5">5</option>
                                </select>
                                <span asp-validation-for="CriteriaAnswers[i].Rating" class="text-danger"></span>
                            </div>

                            @if (Model.CriteriaAnswers[i].CommentAllowed)
                            {
                                <div class="col-md-9">
                                    <label asp-for="CriteriaAnswers[i].Comment" class="form-label">Comment</label>
                                    <textarea asp-for="CriteriaAnswers[i].Comment" class="form-control" rows="2"></textarea>
                                    <span asp-validation-for="CriteriaAnswers[i].Comment" class="text-danger"></span>
                                </div>
                            }
                            else
                            {
                                <input asp-for="CriteriaAnswers[i].Comment" type="hidden" />
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save evaluation</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

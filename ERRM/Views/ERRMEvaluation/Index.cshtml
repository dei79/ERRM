@model IReadOnlyList<ERRM.Models.EvaluationViewModel>

@{
    ViewData["Title"] = "Evaluations";
}

<section class="page-banner">
    <div>
        <span class="eyebrow">Overview</span>
        <h1 class="display-5 mb-2">Evaluations</h1>
        <p class="page-banner__text mb-0">Browse saved reviews, open generated reports, and continue the evaluation workflow.</p>
    </div>
    <a class="btn btn-primary" asp-controller="ERRMEvaluation" asp-action="New">New evaluation</a>
</section>

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2 class="h4">No evaluations stored yet.</h2>
        <p class="mb-0">Create your first review to start building structured evaluation reports.</p>
    </section>
}
else
{
    <section class="data-card">
        <div class="table-responsive">
        <table class="table table-striped align-middle app-table mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Date of birth</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Company</th>
                    <th>Start date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evaluation in Model)
                {
                    <tr>
                        <td>@evaluation.Salutation @evaluation.FirstName @evaluation.LastName</td>
                        <td>@evaluation.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td>@evaluation.Department</td>
                        <td>@evaluation.Position</td>
                        <td>@evaluation.CompanyName</td>
                        <td>@evaluation.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(evaluation.Id))
                            {
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="ERRMEvaluation"
                                   asp-action="Result"
                                   asp-route-id="@evaluation.Id">
                                    Show report
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>
}

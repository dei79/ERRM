@model ERRM.Models.EvaluationResultViewModel

@{
    ViewData["Title"] = "Evaluation Report";
}

<section class="page-banner">
    <div>
        <span class="eyebrow">Report output</span>
        <h1 class="display-6 mb-1">Generated Evaluation Report</h1>
        <p class="text-muted mb-0">@Model.Evaluation.Salutation @Model.Evaluation.FirstName @Model.Evaluation.LastName · @Model.Evaluation.Position</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="ERRMEvaluation" asp-action="Index">Back to evaluations</a>
</section>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="metric-panel h-100">
            <div class="text-muted small">Overall classification</div>
            <div class="fs-4 fw-semibold">@Model.OverallLabel</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-panel h-100">
            <div class="text-muted small">Average rating</div>
            <div class="fs-4 fw-semibold">@Model.AverageRating.ToString("0.00")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-panel h-100">
            <div class="text-muted small">Company</div>
            <div class="fs-5 fw-semibold">@Model.Evaluation.CompanyName</div>
        </div>
    </div>
</div>

<section class="data-card mb-4">
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h4 mb-0">Rendered report</h2>
        <span class="text-muted small">@Model.GenerationSource</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.TemplatePath))
    {
        <div class="text-muted small mb-2">Template: @Model.TemplatePath</div>
    }

    <div id="report-generation"
         data-stream-url="@Url.Action("StreamReport", "ERRMEvaluation", new { id = Model.Evaluation.Id })">
        <div id="report-status" class="alert alert-info mb-3">
            The report is being generated now. Text will appear here as it streams in.
        </div>

        <div id="report-error" class="alert alert-danger d-none"></div>

        <div id="rendered-report" class="report-surface">@Model.RenderedReport</div>
    </div>
</section>

<section class="data-card">
    <h2 class="h4">Criteria formulations</h2>
    <div class="table-responsive">
        <table class="table table-striped align-middle app-table mb-0">
            <thead>
                <tr>
                    <th>Criteria</th>
                    <th>Rating</th>
                    <th>Formulation</th>
                    <th>Comment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var criterion in Model.CriteriaResults)
                {
                    <tr>
                        <td>@criterion.Title</td>
                        <td>@criterion.Rating</td>
                        <td>@criterion.Formulation</td>
                        <td>@(string.IsNullOrWhiteSpace(criterion.Comment) ? "-" : criterion.Comment)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

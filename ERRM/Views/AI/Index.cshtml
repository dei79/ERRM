@model ERRM.Models.HelloWorldAIViewModel

@{
    ViewData["Title"] = "AI Hello World";
}

<section class="page-banner page-banner--stacked">
    <div>
        <span class="eyebrow">AI workspace</span>
        <h1 class="display-6 mb-1">AI Hello World</h1>
        <p class="text-muted mb-0">Test the registered <code>IChatClient</code> with a minimal prompt.</p>
    </div>
</section>

<section class="data-card">
    <form asp-action="Index" asp-controller="AI" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="SystemPrompt" class="form-label"></label>
            <textarea asp-for="SystemPrompt" class="form-control" rows="4"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Prompt" class="form-label"></label>
            <textarea asp-for="Prompt" class="form-control" rows="4"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send Prompt</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <section class="alert alert-danger mt-4 mb-0">
        @Model.ErrorMessage
    </section>
}
else if (!string.IsNullOrWhiteSpace(Model.Response))
{
    <section class="data-card mt-4">
        <h2 class="h4">Model response</h2>
        <div class="report-surface report-surface--light">@Model.Response</div>
    </section>
}
